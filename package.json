{
  "name": "aiaudit",
  "version": "0.1.0",
  "description": "Score PR diffs for AI-generated content. CLI + GitHub Action.",
  "type": "module",
  "bin": {
    "aiaudit": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "dist-action",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "bundle:action": "ncc build src/action.ts -o dist-action --minify --target es2022",
    "test": "node --test --import tsx test/*.test.ts",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run build && npm run bundle:action"
  },
  "keywords": [
    "ai",
    "audit",
    "pull-request",
    "github-action",
    "llm",
    "code-review",
    "detector"
  ],
  "author": "Mukunda Katta",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@types/node": "^22.0.0",
    "@vercel/ncc": "^0.38.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.96.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1"
  }
}
