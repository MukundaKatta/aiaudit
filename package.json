{
  "name": "aiaudit",
  "version": "0.1.0",
  "description": "Score PR diffs for AI-generated content. CLI + GitHub Action.",
  "type": "module",
  "bin": {
    "aiaudit": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
